{
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
        "target": "ESNext",
        "lib": [
            "DOM",
            "ESNext",
            "WebWorker"
        ],
        "allowJs": false,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "incremental": true,
        "plugins": [
            {
                "name": "next",
            },
        ],
        "paths": {
            "@/components/*": [
                "./src/components/*",
            ],
            "@/icons/*": [
                "./public/images/icons/*",
            ],
            "@/styles/*": [
                "./src/styles/*",
            ],
        },
        "types": [
            "@serwist/next/typings",
        ],
    },
    "include": [
        "next-env.d.ts",
        ".next/types/**/*.ts",
        ".next/dev/types/**/*.ts",
        "src/types.d.ts",
        "**/*.ts",
        "**/*.tsx",
        "serwist.config.js",
    ],
    "exclude": [
        "node_modules",
        "public/sw.js",
    ],
}
